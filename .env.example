# ==========================================
# Application Configuration
# ==========================================

# Application environment (local, development, production)
APP_ENV=local

# Application host
APP_HOST=localhost

# Application domain
APP_DOMAIN=transtrack.id

# Public application URL (used for OAuth callbacks)
APP_URL=http://localhost:3000

# Node environment (development, production)
NODE_ENV=development

# ==========================================
# Docker/Deployment Configuration
# ==========================================

# Docker image name
IMAGE_NAME=mock_api

# Docker Compose project name
COMPOSE_PROJECT_NAME=mock_api_production

# Number of replicas for deployment
COMPOSE_REPLICAS=1

# Public port for the application
COMPOSE_PUBLIC_PORT=8425

# ==========================================
# Database Configuration
# ==========================================

# PostgreSQL database connection URL
# Required for database connection
# Example: postgresql://user:password@localhost:5432/mock_service
DATABASE_URL=postgresql://user:password@localhost:5432/mock_service

# ==========================================
# Authentication Configuration
# ==========================================

# Admin email for default login
ADMIN_EMAIL=admin@mock.com

# Admin password for default login
# IMPORTANT: Change this in production!
ADMIN_PASSWORD=admin123

# JWT Secret for signing authentication tokens
# IMPORTANT: Change this to a secure random string in production!
JWT_SECRET=super-secret-jwt-key-change-me

# ==========================================
# Storage Configuration
# ==========================================

# Redis URL for storage (optional)
# If set, Redis will be used for storage instead of filesystem
# This is recommended for production deployments
# Example: redis://localhost:6379
REDIS_URL=

# Vercel deployment flag (optional)
# Set to 'true' when deploying to Vercel
# This automatically enables Redis storage
VERCEL=

# ==========================================
# SSO/OAuth Configuration (Optional)
# ==========================================
# These are configured via the admin UI at /admin/sso
# But you can pre-configure them via environment variables if needed

# Example Keycloak configuration:
# KEYCLOAK_REALM=my-realm
# KEYCLOAK_CLIENT_ID=my-client
# KEYCLOAK_CLIENT_SECRET=my-secret
# KEYCLOAK_BASE_URL=https://keycloak.example.com

# Example Google OAuth configuration:
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# Example GitHub OAuth configuration:
# GITHUB_CLIENT_ID=Iv1.xxxxxxxxxx
# GITHUB_CLIENT_SECRET=your-client-secret

# Example Azure AD configuration:
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_SECRET=your-client-secret

# ==========================================
# Datadog Configuration (APM & RUM)
# ==========================================
# 
# IMPORTANT: For APM to work correctly, you MUST start the app with:
#   npm run start
# Or manually with:
#   node --require dd-trace/init .output/server/index.mjs
#
# Server-side APM (dd-trace) - Required for backend tracing
# DATADOG_API_KEY=your_datadog_api_key_here
# DATADOG_SITE=us5.datadoghq.com
# DATADOG_ENV=production
#
# Client-side RUM (browser) - Required for frontend monitoring  
# DATADOG_APPLICATION_ID=your_application_id_here
# DATADOG_CLIENT_TOKEN=your_client_token_here
# DATADOG_SITE=us5.datadoghq.com
# DATADOG_ENV=production
