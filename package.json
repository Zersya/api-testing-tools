    "@types/better-sqlite3": "^7.6.12",
    "@typescript-eslint/parser": "^8.53.1",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.7.0",
