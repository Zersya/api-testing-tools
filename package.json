    "@types/uuid": "^10.0.0",
    "@vercel/kv": "^1.0.1",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.3",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "marked": "^17.0.1",
    "nuxt": "^4.2.2",
    "perfect-debounce": "^2.0.0",
