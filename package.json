{
  "name": "mock-service",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "nuxt typecheck",
    "build": "nuxt build",
    "build:tauri": "npx nuxi build --preset node-server && node scripts/copy-server.js",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/db/seed.ts",
    "tauri": "tauri",
    "tauri:dev": "bun run build:tauri && cd src-tauri && cargo run --manifest-path Cargo.toml",
    "tauri:build": "cd src-tauri && cargo build --release",
    "tauri:build:bundle": "bun run build:tauri && cd src-tauri && node ../node_modules/@tauri-apps/cli/tauri.js build",
    "lint": "echo 'Running lint check...'"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
