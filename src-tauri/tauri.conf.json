{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "mock-service",
  "version": "1.0.1",
  "identifier": "com.yourcompany.mockservice",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "resources/server/public"
  },
  "app": {
    "windows": [
      {
        "title": "Mock Service",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri://localhost 'unsafe-inline'; connect-src 'self' ipc: tauri: http://127.0.0.1:3001 http://localhost:3001 tauri://localhost;"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": [
      "resources/server/**/*"
    ]
  }
}
